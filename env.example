# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Static HTML pages (upload.html, login.html, signup.html, dashboard.html, pricing.html, cancel.html)
# set window.SUPABASE_URL and window.SUPABASE_ANON_KEY in each page's <head> <script> block.
# Use the same values as above. Do not commit real URLs/keys — copy from a local .env or inject at deploy
# (e.g. Netlify build step: envsubst/sed from VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY into HTML before publish).

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key
STRIPE_PRICE_STARTER=price_your_starter_price_id
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_PRICE_PROPLUS=price_your_proplus_price_id

# Site Configuration
SITE_URL=https://your-domain.com

# Admin Configuration
ADMIN_KEY=yourstrongsecretkey

# Supabase Configuration (Server-side only)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe Webhook Configuration
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# SendGrid Email Configuration
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXX
SUPPORT_EMAIL=info@axis-strategic-media.com